<UserControl x:Class="FileManager.UI.Controls.FileListControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="#FFFFFF">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Barra de herramientas -->
        <Border Grid.Row="0" Background="#F5F5F5" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1" Padding="10,8">
            <StackPanel Orientation="Horizontal" Height="30">
                <Button Command="{Binding FileExplorerViewModel.NavigateBackCommand}" 
                        Width="30" Height="30" Margin="0,0,5,0" ToolTip="Atrás" Content="◄" FontSize="12"
                        Background="#FFFFFF" BorderBrush="#CCCCCC" BorderThickness="1"
                        Padding="0"/>
                <Button Command="{Binding FileExplorerViewModel.NavigateForwardCommand}" 
                        Width="30" Height="30" Margin="0,0,10,0" ToolTip="Adelante" Content="►" FontSize="12"
                        Background="#FFFFFF" BorderBrush="#CCCCCC" BorderThickness="1"
                        Padding="0"/>
                <TextBlock Text="Cargando..." Margin="10,0" VerticalAlignment="Center" FontSize="12"
                           Visibility="{Binding FileExplorerViewModel.IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </StackPanel>
        </Border>

        <!-- DataGrid de archivos -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding FileExplorerViewModel.Items}"
                  SelectedItem="{Binding FileExplorerViewModel.SelectedItem}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  Background="#FFFFFF"
                  BorderThickness="0"
                  MouseDoubleClick="DataGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Nombre" Width="*" MinWidth="200">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="5,0">
                                <TextBlock Margin="0,0,8,0" FontSize="13" VerticalAlignment="Center" Text="{Binding IsDirectory, StringFormat={}{0}}"/>
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="12"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Tipo" Width="120" MinWidth="100" 
                                    Binding="{Binding DisplayType}" IsReadOnly="True"/>

                <DataGridTextColumn Header="Tamaño" Width="100" MinWidth="80" 
                                    Binding="{Binding DisplaySize}" IsReadOnly="True"/>

                <DataGridTextColumn Header="Fecha Modificada" Width="150" MinWidth="120" 
                                    Binding="{Binding ModifiedAt, StringFormat='yyyy-MM-dd HH:mm'}" IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Barra de estado -->
        <Border Grid.Row="3" Background="#EEEEEE" BorderBrush="#DDDDDD" BorderThickness="0,1,0,0" Padding="10,5">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding FileExplorerViewModel.Items.Count, StringFormat='Elementos: {0}'}" 
                           FontSize="11" Foreground="#666666"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
