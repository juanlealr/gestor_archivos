<Window x:Class="FileManager.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:FileManager.UI.Controls"
        mc:Ignorable="d"
        Title="Gestor de Archivos - MVP " Height="600" Width="900">

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" MinWidth="150"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*" MinWidth="300"/>
        </Grid.ColumnDefinitions>

        <DockPanel Grid.Row="0" Grid.ColumnSpan="3" Margin="10,10,10,5" LastChildFill="True">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <Button Content="◄" Width="34" Height="34" Margin="0,0,5,0" Style="{StaticResource IconButton}"
                        Command="{Binding NavigationViewModel.GoBackCommand}"/>
                <Button Content="►" Width="34" Height="34" Margin="0,0,5,0" Style="{StaticResource IconButton}"
                        Command="{Binding NavigationViewModel.GoForwardCommand}"/>
                <Button Content="⬆" Width="34" Height="34" Margin="0,0,10,0" Style="{StaticResource IconButton}"
                        Command="{Binding NavigationViewModel.NavigateUpCommand}"/>
            </StackPanel>

            <Button Content="Ir" Width="60" DockPanel.Dock="Right" Margin="5,0,0,0" Style="{StaticResource MaterialButton}"
                    Command="{Binding NavigationViewModel.NavigateToCommand}"
                    CommandParameter="{Binding Text, ElementName=AddressTextBox}"/>
            <TextBox x:Name="AddressTextBox" Text="{Binding NavigationViewModel.CurrentPath, UpdateSourceTrigger=PropertyChanged, Mode=OneWay}" VerticalContentAlignment="Center"/>
        </DockPanel>

        <Border Grid.Row="1" Grid.ColumnSpan="3" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1" Padding="10,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                    <Button Content="➕ Nuevo" Margin="0,0,5,0" Style="{StaticResource MaterialOutlineButton}" Padding="10,5"
                            Command="{Binding FileExplorerViewModel.NewItemCommand}"
                            CommandParameter="{Binding FileExplorerViewModel.CurrentPath}"/>

                    <Button Content="✂️ Cortar" Margin="0,0,5,0" Style="{StaticResource MaterialOutlineButton}" Padding="10,5"
                            Command="{Binding FileOperationsViewModel.MoveCommand}"
                            CommandParameter="{Binding FileExplorerViewModel.SelectedItem}"/>

                    <Button Content="📋 Copiar" Margin="0,0,5,0" Style="{StaticResource MaterialOutlineButton}" Padding="10,5"
                            Command="{Binding FileOperationsViewModel.CopyCommand}"
                            CommandParameter="{Binding FileExplorerViewModel.SelectedItem}"/>

                    <Button Content="📥 Pegar" Margin="0,0,15,0" Style="{StaticResource MaterialOutlineButton}" Padding="10,5"
                            Command="{Binding FileExplorerViewModel.PasteCommand}"
                            CommandParameter="{Binding FileExplorerViewModel.CurrentPath}"/>

                    <Button Content="✏️ Renombrar" Margin="0,0,5,0" Style="{StaticResource MaterialOutlineButton}" Padding="10,5"
                            Command="{Binding FileOperationsViewModel.RenameCommand}"
                            CommandParameter="{Binding FileExplorerViewModel.SelectedItem}"/>

                    <Button Content="❌ Eliminar" Margin="0,0,15,0" Style="{StaticResource MaterialOutlineButton}" Padding="10,5"
                            Command="{Binding FileOperationsViewModel.DeleteCommand}"
                            CommandParameter="{Binding FileExplorerViewModel.SelectedItem}"/>

                    <Separator Background="{StaticResource BorderBrush}" Width="1" Margin="0,2,15,2"/>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,0">
                        <TextBlock Text="Ver:" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="{StaticResource TextBrush}"/>
                        <ComboBox Width="120" SelectedIndex="{Binding FileExplorerViewModel.ViewMode, Mode=TwoWay}">
                            <ComboBoxItem Content="Detalles"/>
                            <ComboBoxItem Content="Lista"/>
                            <ComboBoxItem Content="Iconos"/>
                        </ComboBox>
                    </StackPanel>

                    <Separator Background="{StaticResource BorderBrush}" Width="1" Margin="15,2"/>

                    <ProgressBar Width="120" Height="20" Margin="10,0,5,0"
                                 Value="{Binding FileOperationsViewModel.CurrentProgress.Percentage, FallbackValue=0, Mode=OneWay}"
                                 Visibility="{Binding FileOperationsViewModel.IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <TextBlock Text="{Binding FileOperationsViewModel.StatusMessage}"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Visibility="{Binding FileOperationsViewModel.IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>

                <Button Grid.Column="1" Content="Propiedades" Margin="0,0,0,0" Style="{StaticResource MaterialOutlineButton}" Padding="8,4" Width="90" HorizontalAlignment="Right"
                        Click="PropertiesButton_Click"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Grid.Column="0" Background="{StaticResource SurfaceBrush}" CornerRadius="5" Margin="10,10,0,10" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <controls:TreeViewControl />
        </Border>

        <GridSplitter Grid.Row="2" Grid.Column="1" HorizontalAlignment="Stretch" Background="Transparent"/>

        <Border Grid.Row="2" Grid.Column="2" Background="{StaticResource SurfaceBrush}" CornerRadius="5" Margin="0,10,10,10" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <Grid>
                <Grid.Resources>
                    <ContextMenu x:Key="FileContextMenu">
                        <MenuItem Header="Abrir"
                                  Command="{Binding DataContext.FileExplorerViewModel.OpenFileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                  CommandParameter="{Binding}"/>
                        <MenuItem Header="Renombrar"
                                  Command="{Binding DataContext.FileOperationsViewModel.RenameCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                  CommandParameter="{Binding}"/>
                        <MenuItem Header="Copiar"
                                  Command="{Binding DataContext.FileOperationsViewModel.CopyCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                  CommandParameter="{Binding}"/>
                        <MenuItem Header="Mover a..." Click="MoveToMenuItem_Click" CommandParameter="{Binding}"/>
                        <MenuItem Header="Eliminar"
                                  Command="{Binding DataContext.FileOperationsViewModel.DeleteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                  CommandParameter="{Binding}"/>
                        <Separator/>
                        <MenuItem Header="Propiedades" Click="PropertiesMenuItem_Click" CommandParameter="{Binding}"/>
                        <MenuItem Header="{Binding DataContext.SelectionViewModel.SelectionCount, RelativeSource={RelativeSource AncestorType=Window}, StringFormat=Copiar {0} elementos}"
                                  Visibility="{Binding DataContext.SelectionViewModel.HasMultipleSelection, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}"
                                  Click="BatchCopyMenuItem_Click"/>
                        <MenuItem Header="{Binding DataContext.SelectionViewModel.SelectionCount, RelativeSource={RelativeSource AncestorType=Window}, StringFormat=Eliminar {0} elementos}"
                                  Visibility="{Binding DataContext.SelectionViewModel.HasMultipleSelection, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}"
                                  Command="{Binding DataContext.SelectionViewModel.BatchDeleteCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    </ContextMenu>
                </Grid.Resources>

                <ListView x:Name="DetailsView" ItemsSource="{Binding FileExplorerViewModel.Items}"
                          SelectedItem="{Binding FileExplorerViewModel.SelectedItem}"
                          SelectionMode="Extended"
                          ContextMenu="{StaticResource FileContextMenu}"
                          Visibility="{Binding FileExplorerViewModel.IsDetailsView, Converter={StaticResource BoolToVisibilityConverter}}"
                          SelectionChanged="OnListSelectionChanged"
                          MouseDoubleClick="OnItemDoubleClick">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Nombre" DisplayMemberBinding="{Binding Name}" Width="250"/>
                            <GridViewColumn Header="Tipo" DisplayMemberBinding="{Binding DisplayType}" Width="150"/>
                            <GridViewColumn Header="Tamaño" DisplayMemberBinding="{Binding DisplaySize}" Width="120"/>
                            <GridViewColumn Header="Fecha Modificación" DisplayMemberBinding="{Binding ModifiedAt, StringFormat='yyyy-MM-dd HH:mm'}" Width="170"/>
                        </GridView>
                    </ListView.View>
                </ListView>

                <ListView x:Name="ListViewMode" ItemsSource="{Binding FileExplorerViewModel.Items}"
                          SelectedItem="{Binding FileExplorerViewModel.SelectedItem}"
                          SelectionMode="Extended"
                          ContextMenu="{StaticResource FileContextMenu}"
                          Visibility="{Binding FileExplorerViewModel.IsListView, Converter={StaticResource BoolToVisibilityConverter}}"
                          SelectionChanged="OnListSelectionChanged"
                          MouseDoubleClick="OnItemDoubleClick">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" Padding="10,5" FontSize="12"/>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <ItemsControl ItemsSource="{Binding FileExplorerViewModel.Items}"
                              Visibility="{Binding FileExplorerViewModel.IsIconsView, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Background="White" Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Width="100" Height="100" Margin="5">
                                <Border Background="#F0F0F0" CornerRadius="4" BorderBrush="#DDDDDD" BorderThickness="1">
                                    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding IsDirectory, Converter={StaticResource DirectoryIconConverter}}"
                                                       FontSize="32" HorizontalAlignment="Center" Margin="0,5"/>
                                            <TextBlock Text="{Binding Name}" FontSize="10" HorizontalAlignment="Center"
                                                       TextAlignment="Center" TextWrapping="Wrap" MaxWidth="90"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <StatusBar Grid.Row="3" Grid.ColumnSpan="3" Background="#EEEEEE">
            <StatusBarItem>
                <TextBlock Text="{Binding SelectionViewModel.SelectionSummary}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" Visibility="{Binding SelectionViewModel.IsBatchOperationRunning, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ProgressBar Width="120" Height="12" Value="{Binding SelectionViewModel.BatchProgress, Mode=OneWay}" Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding SelectionViewModel.BatchStatusMessage}" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <Button Content="Cancelar" Margin="10,0,0,0" Padding="8,4"
                            Command="{Binding SelectionViewModel.CancelBatchCommand}"/>
                </StackPanel>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding FileExplorerViewModel.Items.Count, StringFormat='Elementos: {0}'}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>