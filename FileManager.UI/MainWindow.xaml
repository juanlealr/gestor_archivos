<Window x:Class="FileManager.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FileManager.UI"
        mc:Ignorable="d"
        Title="Gestor de Archivos" Height="600" Width="1000">
    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Barra de Herramientas -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10" Height="40">
            <Button Command="{Binding FileExplorerViewModel.NavigateBackCommand}" 
                    Width="40" Height="40" Margin="5" ToolTip="Atrás" Content="◄" FontSize="16"/>
            <Button Command="{Binding FileExplorerViewModel.NavigateForwardCommand}" 
                    Width="40" Height="40" Margin="5" ToolTip="Adelante" Content="►" FontSize="16"/>
            <Separator Width="1" Background="#CCCCCC" Margin="5,0"/>
            <TextBox Width="400" Margin="5" 
                     Text="{Binding FileExplorerViewModel.CurrentPath, Mode=OneWay}" 
                     IsReadOnly="True" VerticalAlignment="Center" Padding="5"/>
        </StackPanel>

        <!-- Separador -->
        <Border Grid.Row="1" Height="1" Background="#DDDDDD"/>

        <!-- Panel Principal con Unidades y Explorador -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Panel de Unidades -->
            <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#DDDDDD" BorderThickness="0,0,1,0">
                <StackPanel Margin="10">
                    <TextBlock Text="Unidades" FontWeight="Bold" Margin="0,0,0,10"/>
                    <ListBox ItemsSource="{Binding FileExplorerViewModel.Drives}" 
                             SelectedItem="{Binding FileExplorerViewModel.SelectedItem}"
                             Background="Transparent" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.FileExplorerViewModel.NavigateToPathCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding Name}"
                                        Content="{Binding DisplayName}" 
                                        Background="Transparent" 
                                        BorderThickness="0"
                                        HorizontalAlignment="Stretch"
                                        Padding="5"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <!-- Separador Vertical -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#DDDDDD" Cursor="SizeWE"/>

            <!-- Explorador de Archivos -->
            <Border Grid.Column="2" Background="#FFFFFF">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Indicador de Carga -->
                    <TextBlock Grid.Row="0" Text="Cargando..." Margin="10" 
                               Visibility="{Binding FileExplorerViewModel.IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <!-- Lista de Archivos -->
                    <ListBox Grid.Row="1" 
                             ItemsSource="{Binding FileExplorerViewModel.Items}"
                             SelectedItem="{Binding FileExplorerViewModel.SelectedItem}"
                             Background="#FFFFFF" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.FileExplorerViewModel.OpenFileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        HorizontalAlignment="Stretch"
                                        Padding="10">
                                    <Grid HorizontalAlignment="Left">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding IsDirectory, StringFormat='{0}'}" 
                                                   VerticalAlignment="Center" FontSize="14" Width="20"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" 
                                                   VerticalAlignment="Center" Margin="5,0,0,0"/>
                                        <TextBlock Grid.Column="2" Text="{Binding DisplaySize}" 
                                                   VerticalAlignment="Center" Foreground="#666666" FontSize="12"/>
                                        <TextBlock Grid.Column="3" Text="{Binding ModifiedAt, StringFormat='yyyy-MM-dd HH:mm'}" 
                                                   VerticalAlignment="Center" Foreground="#999999" FontSize="11"/>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <!-- Barra de Estado -->
        <Border Grid.Row="3" Height="30" Background="#EEEEEE" BorderBrush="#DDDDDD" BorderThickness="0,1,0,0">
            <TextBlock Margin="10,0" VerticalAlignment="Center" 
                       Text="{Binding FileExplorerViewModel.Items.Count, StringFormat='Elementos: {0}'}"/>
        </Border>
    </Grid>
</Window>
