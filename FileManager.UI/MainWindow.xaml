<Window x:Class="FileManager.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Gestor de Archivos - MVP" Height="600" Width="900">

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" MinWidth="150"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*" MinWidth="300"/>
        </Grid.ColumnDefinitions>

        <DockPanel Grid.Row="0" Grid.ColumnSpan="3" Margin="10,10,10,5">
            <Button Content="Ir" Width="60" DockPanel.Dock="Right" Margin="5,0,0,0" Style="{StaticResource MaterialButton}"
                    Command="{Binding FileExplorerViewModel.NavigateToPathCommand}"
                    CommandParameter="{Binding Text, ElementName=AddressTextBox}"/>
            <TextBox x:Name="AddressTextBox" Text="{Binding FileExplorerViewModel.CurrentPath, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" VerticalContentAlignment="Center"/>
        </DockPanel>

        <Border Grid.Row="1" Grid.ColumnSpan="3" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1" Padding="10,5">
            <StackPanel Orientation="Horizontal">
                <Button Content="➕ Nuevo" Margin="0,0,5,0" Style="{StaticResource MaterialOutlineButton}" Padding="10,5"
                        Command="{Binding FileExplorerViewModel.NewItemCommand}"
                        CommandParameter="{Binding FileExplorerViewModel.CurrentPath}"/>

                <Button Content="✂️ Cortar" Margin="0,0,5,0" Style="{StaticResource MaterialOutlineButton}" Padding="10,5"
                        Command="{Binding FileExplorerViewModel.CutCommand}"
                        CommandParameter="{Binding FileExplorerViewModel.SelectedItem}"/>

                <Button Content="📋 Copiar" Margin="0,0,5,0" Style="{StaticResource MaterialOutlineButton}" Padding="10,5"
                        Command="{Binding FileExplorerViewModel.CopyCommand}"
                        CommandParameter="{Binding FileExplorerViewModel.SelectedItem}"/>

                <Button Content="📥 Pegar" Margin="0,0,5,0" Style="{StaticResource MaterialOutlineButton}" Padding="10,5"
                        Command="{Binding FileExplorerViewModel.PasteCommand}"
                        CommandParameter="{Binding FileExplorerViewModel.CurrentPath}"/>

                <Button Content="✏️ Renombrar" Margin="0,0,5,0" Style="{StaticResource MaterialOutlineButton}" Padding="10,5"
                        Command="{Binding FileExplorerViewModel.RenameCommand}"
                        CommandParameter="{Binding FileExplorerViewModel.SelectedItem}"/>

                <Button Content="❌ Eliminar" Margin="0,0,15,0" Style="{StaticResource MaterialOutlineButton}" Padding="10,5"
                        Command="{Binding FileExplorerViewModel.DeleteCommand}"
                        CommandParameter="{Binding FileExplorerViewModel.SelectedItem}"/>

                <Separator Background="{StaticResource BorderBrush}" Width="1" Margin="5,2"/>

                <ComboBox Width="130" SelectedIndex="{Binding FileExplorerViewModel.ViewMode}"
                          Margin="15,0,5,0" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}">
                    <ComboBoxItem Content="Detalles" Tag="0"/>
                    <ComboBoxItem Content="Lista" Tag="1"/>
                    <ComboBoxItem Content="Iconos" Tag="2"/>
                </ComboBox>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Grid.Column="0" Background="{StaticResource SurfaceBrush}" CornerRadius="5" Margin="10,10,0,10" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#F5F5F5" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1" Padding="10,8">
                    <TextBlock Text="Unidades" FontWeight="Bold" FontSize="12" Foreground="#333333"/>
                </Border>
                <ListBox Grid.Row="1" ItemsSource="{Binding FileExplorerViewModel.Drives}"
                         Background="White" BorderThickness="0" Padding="0,5">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Name, StringFormat='💾 {0}'}" Padding="10,8" Margin="5,2"
                                    Command="{Binding DataContext.FileExplorerViewModel.NavigateToDriveCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    Background="Transparent" Foreground="{StaticResource TextBrush}"
                                    BorderBrush="Transparent" BorderThickness="0"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" FontSize="12"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <GridSplitter Grid.Row="2" Grid.Column="1" HorizontalAlignment="Stretch" Background="Transparent"/>

        <Border Grid.Row="2" Grid.Column="2" Background="{StaticResource SurfaceBrush}" CornerRadius="5" Margin="0,10,10,10" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <Grid>
                <!-- Vista Detalles (GridView) -->
                <ListView x:Name="DetailsView" ItemsSource="{Binding FileExplorerViewModel.Items}"
                          SelectedItem="{Binding FileExplorerViewModel.SelectedItem}"
                          Visibility="{Binding FileExplorerViewModel.IsDetailsView, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Nombre" DisplayMemberBinding="{Binding Name}" Width="250"/>
                            <GridViewColumn Header="Tipo" DisplayMemberBinding="{Binding DisplayType}" Width="150"/>
                            <GridViewColumn Header="Tamaño" DisplayMemberBinding="{Binding DisplaySize}" Width="120"/>
                            <GridViewColumn Header="Fecha Modificación" DisplayMemberBinding="{Binding ModifiedAt, StringFormat='yyyy-MM-dd HH:mm'}" Width="170"/>
                        </GridView>
                    </ListView.View>
                </ListView>

                <!-- Vista Lista -->
                <ListView x:Name="ListViewMode" ItemsSource="{Binding FileExplorerViewModel.Items}"
                          SelectedItem="{Binding FileExplorerViewModel.SelectedItem}"
                          Visibility="{Binding FileExplorerViewModel.IsListView, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" Padding="10,5" FontSize="12"/>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Vista Iconos -->
                <ItemsControl ItemsSource="{Binding FileExplorerViewModel.Items}"
                              Visibility="{Binding FileExplorerViewModel.IsIconsView, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Background="White" Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Width="100" Height="100" Margin="5">
                                <Border Background="#F0F0F0" CornerRadius="4" BorderBrush="#DDDDDD" BorderThickness="1">
                                    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding IsDirectory, Converter={StaticResource DirectoryIconConverter}}"
                                                       FontSize="32" HorizontalAlignment="Center" Margin="0,5"/>
                                            <TextBlock Text="{Binding Name}" FontSize="10" HorizontalAlignment="Center"
                                                       TextAlignment="Center" TextWrapping="Wrap" MaxWidth="90"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <StatusBar Grid.Row="3" Grid.ColumnSpan="3" Background="#EEEEEE">
            <StatusBarItem>
                <TextBlock Text="Listo" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>