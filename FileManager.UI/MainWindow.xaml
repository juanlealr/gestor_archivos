<Window x:Class="FileManager.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FileManager.UI"
        xmlns:controls="clr-namespace:FileManager.UI.Controls"
        mc:Ignorable="d"
        Title="Gestor de Archivos" Height="700" Width="1200">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <Style x:Key="FileListRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Margin" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F0F0"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E3F2FD"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Barra de Herramientas Superior -->
        <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1" Padding="10,8">
            <StackPanel Orientation="Horizontal" Height="35">
                <Button Command="{Binding FileExplorerViewModel.NavigateBackCommand}" 
                        Width="35" Height="35" ToolTip="Atrás" Content="◄" FontSize="14"
                        Background="#FFFFFF" BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,0,5,0"/>
                <Button Command="{Binding FileExplorerViewModel.NavigateForwardCommand}" 
                        Width="35" Height="35" ToolTip="Adelante" Content="►" FontSize="14"
                        Background="#FFFFFF" BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,0,10,0"/>
                <Separator Width="1" Background="#CCCCCC" Margin="5,0"/>
                <TextBox Width="300" Margin="10,0,0,0"
                         Text="{Binding FileExplorerViewModel.CurrentPath, Mode=OneWay}" 
                         IsReadOnly="True" VerticalAlignment="Center" Padding="5"
                         Background="#F9F9F9" BorderBrush="#DDDDDD" BorderThickness="1"/>
            </StackPanel>
        </Border>

        <!-- Breadcrumb Bar -->
        <controls:BreadcrumbBar Grid.Row="1" DataContext="{Binding}"/>

        <!-- Panel Principal: Árbol (Izquierda) + Lista (Derecha) -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" MinWidth="150"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="300"/>
            </Grid.ColumnDefinitions>

            <!-- Panel Izquierdo: TreeView de Carpetas -->
            <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#DDDDDD" BorderThickness="0,0,1,0">
                <controls:TreeViewControl/>
            </Border>

            <!-- Separador Vertical Redimensionable -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" 
                          Background="#DDDDDD" Cursor="SizeWE" ShowsPreview="True"/>

            <!-- Panel Derecho: Lista de Archivos -->
            <Border Grid.Column="2" Background="#FFFFFF">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Indicador de Carga -->
                    <TextBlock Grid.Row="0" Text="Cargando..." Margin="10" 
                               Visibility="{Binding FileExplorerViewModel.IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <!-- Lista de Archivos -->
                    <ListBox Grid.Row="1" 
                             ItemsSource="{Binding FileExplorerViewModel.Items}"
                             SelectedItem="{Binding FileExplorerViewModel.SelectedItem}"
                             Background="#FFFFFF" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.FileExplorerViewModel.OpenFileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        HorizontalAlignment="Stretch"
                                        Padding="10">
                                    <Grid HorizontalAlignment="Left">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding IsDirectory, StringFormat='{0}'}" 
                                                   VerticalAlignment="Center" FontSize="14" Width="20"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" 
                                                   VerticalAlignment="Center" Margin="5,0,0,0"/>
                                        <TextBlock Grid.Column="2" Text="{Binding DisplaySize}" 
                                                   VerticalAlignment="Center" Foreground="#666666" FontSize="12"/>
                                        <TextBlock Grid.Column="3" Text="{Binding ModifiedAt, StringFormat='yyyy-MM-dd HH:mm'}" 
                                                   VerticalAlignment="Center" Foreground="#999999" FontSize="11"/>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
